# --- Serveur ---
PORT=4010
NODE_ENV=production

# --- Sécurité ---
JWT_SECRET=a7f3b9c1e4d2f6a8b5c7d9e1f3a5b7c9d2e4f6a8b1c3d5e7f9a1b3c5d7e9f1
ADMIN_USERNAME=aenews-commander
ADMIN_PASSWORD=VpsAdmin2025Secure!

# --- Token JWT ---
TOKEN_EXPIRY=2h
REFRESH_EXPIRY=7d

# --- API IA: Alibaba Cloud DashScope (OpenAI-compatible) ---
# DashScope compatible-mode endpoint works with OpenAI SDK natively
AI_PROVIDER=alibaba-cloud
OPENAI_API_KEY=sk-b8397ec88a6d458b80c7877040dc1d99
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# --- ia-core Hub (fallback + NLP avancé) ---
IA_CORE_URL=http://127.0.0.1:8800
IA_CORE_API_KEY=61f9e57da29b7089d9c21d093066ea9182f273904206068a2a3e460af1c073bc

# --- Alibaba Cloud Multi-Model ---
ALIBABA_CLOUD_API_KEY=sk-b8397ec88a6d458b80c7877040dc1d99
ALIBABA_FAST_MODEL=qwen-turbo
ALIBABA_BALANCED_MODEL=qwen-plus
ALIBABA_SMART_MODEL=qwen-max
ALIBABA_CODE_MODEL=qwen-coder-plus
ALIBABA_LONG_MODEL=qwen-long

# --- Configuration Agent ---
AGENT_WORKSPACE=/opt/agent-projects
ALLOWED_DOCKER_NETWORKS=agent-network
MAX_CONCURRENT_TASKS=3

# --- Sécurité avancée ---
ENABLE_DRY_RUN=false
REQUIRE_APPROVAL=true
ALLOWED_COMMANDS=docker,npm,node,git,mkdir,chmod,systemctl,apt,curl,wget,pm2,nginx

# --- Alertes Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- V2: Approval Workflow ---
APPROVAL_TIMEOUT_MINUTES=30
BASE_URL=https://vps.aenews.net

# --- V2: RAG Knowledge Base ---
CHROMADB_URL=http://127.0.0.1:8001
RAG_METRICS_INTERVAL=5
RAG_CONFIG_INTERVAL=60

# --- V2: ReAct Loop ---
REACT_MAX_ITERATIONS=10

# --- CORS ---
ALLOWED_ORIGINS=https://vps.aenews.net,https://command.aenews.net,https://aenews.net

# --- Base de données SQLite ---
DATABASE_URL=file:/opt/vps-devops-agent/data/devops-agent.db

