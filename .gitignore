# ============================================================
# VPS DevOps Agent — .gitignore
# ============================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnpm-debug.log*

# Environment Variables (NEVER commit)
.env
.env.local
.env.*.local
.env.production

# Database
*.db
*.sqlite
*.sqlite3
data/
backend/database.sqlite
backend/devops-agent.db

# Logs
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# PM2
.pm2/
pm2.json

# Runtime data
lib-cov
coverage/
.nyc_output/

# Build outputs
dist/
build/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
Desktop.ini

# Backups
*.backup
*.bak
*.old
*.tar.gz
*.zip
backups/
.archives-backups-*/

# Security (NEVER commit)
*.pem
*.key
*.crt
*.cer
.git-credentials

# Temporary files
tmp/
temp/
*.tmp

# Configuration backups
*.backup-*
.env.backup-*

# Test/debug files that should never be deployed
*.disabled-*
*.clean
*.before-*
*.with-*

# Python artifacts
__pycache__/
*.pyc
.pytest_cache/

# Archived docs (keep in git for history but not in root)
# docs/archive/ is kept for reference
