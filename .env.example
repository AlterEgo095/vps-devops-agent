# ============================================================
# VPS DevOps Agent — Configuration d'environnement
# ============================================================
# IMPORTANT: Copiez ce fichier en .env et remplissez TOUTES
# les valeurs obligatoires avant de demarrer l'application.
# NE commitez JAMAIS le fichier .env dans Git.
# ============================================================

# --- Serveur ---
PORT=4000
NODE_ENV=production

# --- Securite (OBLIGATOIRE) ---
# [REQUIRED] Minimum 32 caracteres aleatoires.
# Generez-en un avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Le serveur REFUSE de demarrer si cette valeur est absente ou trop courte.
JWT_SECRET=REMPLACEZ_PAR_UNE_CHAINE_ALEATOIRE_DE_MIN_32_CARACTERES

# [REQUIRED] Identifiant admin pour le premier demarrage.
ADMIN_USERNAME=admin

# [REQUIRED] Minimum 8 caracteres. Le serveur refuse de demarrer sans ce parametre.
# Ne jamais utiliser 'admin2025', 'Admin2024' ou toute valeur par defaut connue.
ADMIN_PASSWORD=REMPLACEZ_PAR_VOTRE_MOT_DE_PASSE_SECURISE

# --- Token JWT (optionnel — durees par defaut) ---
# Duree de vie du token d'acces (defaut: 1h)
TOKEN_EXPIRY=1h
# Duree de vie du token de refresh (defaut: 7d)
REFRESH_EXPIRY=7d

# --- API IA (choisir un provider) ---
OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
AI_PROVIDER=openai

# --- Configuration Agent ---
AGENT_WORKSPACE=/opt/agent-projects
ALLOWED_DOCKER_NETWORKS=agent-network
MAX_CONCURRENT_TASKS=3

# --- Securite avancee ---
ENABLE_DRY_RUN=false
REQUIRE_APPROVAL=true
ALLOWED_COMMANDS=docker,npm,node,git,mkdir,chmod,systemctl,apt,curl,wget,pm2,nginx

# --- Alertes Email (optionnel) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# --- Alertes Telegram (optionnel) ---
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# --- V2 Features: Approval Workflow ---
# Telegram Bot pour les demandes d'approbation des operations CRITIQUES
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# Webhook URL pour n8n/WhatsApp (alternative a Telegram)
# APPROVAL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/approvals
# Base URL du serveur (pour generer les liens d'approbation)
# BASE_URL=https://your-domain.com

# --- V2 Features: RAG Knowledge Base ---
# ChromaDB server URL (lancer avec: docker run -p 8000:8000 chromadb/chroma)
# CHROMADB_URL=http://localhost:8000
# RAG auto-collect interval (minutes)
# RAG_METRICS_INTERVAL=5
# RAG_CONFIG_INTERVAL=60

# --- V2 Features: ReAct Loop ---
# Maximum iterations for ReAct reasoning loop
# REACT_MAX_ITERATIONS=10
# Default approval timeout (minutes)
# APPROVAL_TIMEOUT_MINUTES=30

# --- CORS (optionnel, recommande en production) ---
# ALLOWED_ORIGINS=https://votre-domaine.com

# --- Paiements (optionnel) ---
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
